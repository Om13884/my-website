    {
      "parameters": {
        "promptType": "define",
        "text": "=New contact form submission:\n\nName: {{ $json.body.firstName }} {{ $json.body.lastName }}\nEmail: {{ $json.body.email }}\nPhone: {{ $json.body.phone }}\nCompany: {{ $json.body.company }}\nMonthly Revenue: {{ $json.body.revenue }}\nService: {{ $json.body.service }}\nTimeline: {{ $json.body.timeline }}\nSubmitted: {{ $json.body.submittedAt }}\n\nMessage:\n{{ $json.body.message }}\n\nAnalyze this lead and return ONLY the lead summary — no JSON, no code blocks, just plain text.",
        "options": {
          "systemMessage": "role :You are an AI assistant for Omkar Biradar, an embedded AI automation consultant in Bangalore, India.\n\ntask: A new contact form has arrived. Analyze it and return a plain-text LEAD SUMMARY for Omkar.\n\nFormat:\n- Line 1: Score — 🔥 HOT / 🟡 WARM / ❄️ COLD (judge by message clarity, urgency, budget, company size)\n- Bullet points: name, company, email, service requested, revenue range, timeline, core problem they need solved, any red flags\n- Last line — Recommended action: one clear next step (e.g. \"Call within 2 hours — specific ask, strong budget signal\")\n\nReturn plain text only. No JSON. No markdown headers.\n\nnotes : before writting aboute the slots available check the calender that what are the times that we are has a slots  available on that bases only you will provide the slots to them. \n\n"
        }
      },
      "id": "0f4a2436-0373-4460-85f8-273e9b76bcf9",
      "name": "AI Agent: Score Lead",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -736,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "// ── Parse AI lead summary + generate submission ID + IST time slots ──\n\nconst agentOut = $input.first().json;\nconst raw = $('Receive Form (Webhook)').first().json;\n\n// n8n webhook node puts body fields at top-level AND keeps a 'body' object.\n// Prefer top-level fields; fall back to body sub-object.\nconst form = (raw.firstName || raw.email) ? raw : (raw.body || raw);\n\nconst firstName   = String(form.firstName   || '').trim();\nconst lastName    = String(form.lastName    || '').trim();\nconst email       = String(form.email       || '').trim();\nconst phone       = String(form.phone       || '').trim();\nconst company     = String(form.company     || '').trim();\nconst revenue     = String(form.revenue     || '').trim();\nconst service     = String(form.service     || '').trim();\nconst timeline    = String(form.timeline    || '').trim();\nconst message     = String(form.message     || '').trim();\nconst submittedAt = String(form.submittedAt || new Date().toISOString());\n\n// Extract lead summary from agent output\nconst leadSummary = agentOut.output || agentOut.text || agentOut.message?.content ||\n  '⚠️ AI scoring unavailable — review manually.';\n\n// ── Time slot generation (Omkar availability: Mon–Fri IST) ──\nconst IST = 19800000; // UTC+5:30 in ms\n\nfunction istLabel(utcMs) {\n  const d = new Date(utcMs + IST);\n  const DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];\n  const MON  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\n  const h = d.getUTCHours(), m = d.getUTCMinutes();\n  const ap = h >= 12 ? 'PM' : 'AM';\n  const h12 = h % 12 || 12;\n  return DAYS[d.getUTCDay()] + ', ' + d.getUTCDate() + ' ' + MON[d.getUTCMonth()] +\n         ' at ' + h12 + ':' + String(m).padStart(2,'0') + ' ' + ap + ' IST';\n}\n\nconst PREFS = [{h:10,m:30},{h:12,m:0},{h:15,m:0},{h:17,m:0}];\nconst now = new Date();\nconst slots = [];\nlet dayOffset = 1;\n\nwhile (slots.length < 5 && dayOffset <= 14) {\n  const baseUTC = new Date(now.getTime() + dayOffset * 86400000);\n  const baseIST = new Date(baseUTC.getTime() + IST);\n  const dow = baseIST.getUTCDay();\n  if (dow >= 1 && dow <= 5) {\n    for (const p of PREFS) {\n      if (slots.length >= 5) break;\n      const utcMs = Date.UTC(\n        baseIST.getUTCFullYear(), baseIST.getUTCMonth(), baseIST.getUTCDate(),\n        p.h, p.m, 0, 0\n      ) - IST;\n      slots.push({\n        index:    slots.length + 1,\n        label:    istLabel(utcMs),\n        startISO: new Date(utcMs).toISOString(),\n        endISO:   new Date(utcMs + 1800000).toISOString()\n      });\n    }\n  }\n  dayOffset++;\n}\n\nconst submissionId = 'NXF-' + Date.now();\nconst slotsJSON = JSON.stringify(slots);\nconst slotsText = slots.map(s => 'Option ' + s.index + ': ' + s.label).join('\\n');\nconst slotsHTML = slots.map(s =>\n  '<p style=\"margin:6px 0;\"><strong>Option ' + s.index + ':</strong> ' + s.label + '</p>'\n).join('');\n\n// Return ONLY clean form fields — no webhook metadata (headers, params, body, etc.)\nreturn [{\n  json: {\n    firstName,\n    lastName,\n    email,\n    phone,\n    company,\n    revenue,\n    service,\n    timeline,\n    message,\n    submittedAt,\n    leadSummary,\n    submissionId,\n    slotsJSON,\n    slotsText,\n    slotsHTML\n  }\n}];"
      },
